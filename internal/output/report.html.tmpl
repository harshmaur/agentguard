<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>AgentGuard Report</title>
<style>
  :root {
    --bg: #fafaf7;
    --fg: #1a1a1a;
    --muted: #6b7280;
    --card: #ffffff;
    --border: #e5e5e5;
    --accent: #1a1a1a;
    --critical: #b91c1c;
    --critical-bg: #fef2f2;
    --high: #c2410c;
    --high-bg: #fff7ed;
    --medium: #b45309;
    --medium-bg: #fffbeb;
    --low: #525252;
    --low-bg: #f5f5f5;
    --tax-enforced: #16a34a;
    --tax-detectable: #2563eb;
    --tax-advisory: #6b7280;
  }
  @media (prefers-color-scheme: dark) {
    :root {
      --bg: #0a0a0a;
      --fg: #e5e5e5;
      --muted: #9ca3af;
      --card: #1a1a1a;
      --border: #262626;
      --accent: #e5e5e5;
      --critical: #ef4444;
      --critical-bg: #2c1010;
      --high: #f97316;
      --high-bg: #2a1808;
      --medium: #eab308;
      --medium-bg: #28200a;
      --low: #a3a3a3;
      --low-bg: #1f1f1f;
      --tax-enforced: #4ade80;
      --tax-detectable: #60a5fa;
      --tax-advisory: #9ca3af;
    }
  }
  * { box-sizing: border-box; }
  html, body { margin: 0; padding: 0; }
  body {
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", system-ui, sans-serif;
    background: var(--bg);
    color: var(--fg);
    font-size: 14px;
    line-height: 1.5;
    -webkit-font-smoothing: antialiased;
  }
  .wrap { max-width: 980px; margin: 0 auto; padding: 32px 24px 64px; }
  header { display: flex; align-items: baseline; justify-content: space-between; margin-bottom: 24px; }
  header h1 { font-size: 22px; margin: 0; letter-spacing: -0.01em; font-weight: 600; }
  header .ver { font-size: 12px; color: var(--muted); }

  .summary {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 24px;
    margin-bottom: 24px;
  }
  .summary-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
  }
  .stat .num { font-size: 28px; font-weight: 600; letter-spacing: -0.02em; }
  .stat .label { font-size: 12px; color: var(--muted); text-transform: uppercase; letter-spacing: 0.04em; margin-top: 2px; }
  .stat.critical .num { color: var(--critical); }
  .stat.high .num { color: var(--high); }
  .stat.medium .num { color: var(--medium); }
  .stat.low .num { color: var(--low); }

  .self-audit {
    margin-top: 18px;
    padding: 10px 14px;
    border-radius: 6px;
    font-size: 13px;
    font-family: ui-monospace, "SF Mono", Menlo, monospace;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .self-audit.clean { background: rgba(34,197,94,0.1); color: var(--tax-enforced); border: 1px solid rgba(34,197,94,0.3); }
  .self-audit.tampered { background: var(--critical-bg); color: var(--critical); border: 1px solid var(--critical); }
  .self-audit.skipped { background: var(--low-bg); color: var(--muted); border: 1px solid var(--border); }

  .meta {
    margin-top: 14px;
    font-size: 12px;
    color: var(--muted);
    display: flex;
    flex-wrap: wrap;
    gap: 18px;
  }
  .meta span { display: inline-flex; align-items: center; gap: 5px; }

  h2 { font-size: 14px; text-transform: uppercase; letter-spacing: 0.06em; color: var(--muted); margin: 28px 0 12px; font-weight: 600; }

  .findings { list-style: none; padding: 0; margin: 0; }
  .finding {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 18px 20px;
    margin-bottom: 12px;
  }
  .finding-head { display: flex; justify-content: space-between; align-items: flex-start; gap: 12px; margin-bottom: 10px; }
  .finding-title { font-size: 15px; font-weight: 600; margin: 0; line-height: 1.3; }
  .badges { display: flex; gap: 6px; flex-shrink: 0; }
  .badge {
    font-size: 11px;
    font-weight: 600;
    padding: 3px 8px;
    border-radius: 4px;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    white-space: nowrap;
  }
  .badge.critical { background: var(--critical-bg); color: var(--critical); }
  .badge.high { background: var(--high-bg); color: var(--high); }
  .badge.medium { background: var(--medium-bg); color: var(--medium); }
  .badge.low { background: var(--low-bg); color: var(--low); }
  .badge.tax {
    background: transparent;
    border: 1px solid currentColor;
  }
  .badge.tax.enforced { color: var(--tax-enforced); }
  .badge.tax.detectable { color: var(--tax-detectable); }
  .badge.tax.advisory { color: var(--tax-advisory); }

  .path {
    font-family: ui-monospace, "SF Mono", Menlo, monospace;
    font-size: 12px;
    color: var(--muted);
    margin-bottom: 8px;
    word-break: break-all;
  }
  .description { color: var(--fg); margin-bottom: 10px; }
  .match {
    background: var(--low-bg);
    border-left: 3px solid var(--border);
    padding: 8px 12px;
    font-family: ui-monospace, "SF Mono", Menlo, monospace;
    font-size: 12px;
    border-radius: 0 4px 4px 0;
    margin-bottom: 8px;
    overflow-x: auto;
    white-space: pre-wrap;
    word-break: break-all;
  }
  .fix {
    font-size: 13px;
    color: var(--fg);
    border-top: 1px solid var(--border);
    padding-top: 10px;
    margin-top: 10px;
  }
  .fix b { font-weight: 600; }
  .rule-id { font-family: ui-monospace, monospace; font-size: 11px; color: var(--muted); }

  footer {
    margin-top: 48px;
    padding-top: 18px;
    border-top: 1px solid var(--border);
    color: var(--muted);
    font-size: 12px;
    text-align: center;
  }
  footer a { color: var(--accent); text-decoration: none; }
  footer a:hover { text-decoration: underline; }

  .empty {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 48px 24px;
    text-align: center;
    color: var(--muted);
  }
  .empty .check { font-size: 48px; color: var(--tax-enforced); margin-bottom: 8px; }
</style>
</head>
<body>
<div class="wrap">
  <header>
    <h1>AgentGuard Report</h1>
    <span class="ver">{{.Version}}</span>
  </header>

  {{ $c := counts .Findings }}

  <section class="summary">
    <div class="summary-grid">
      <div class="stat critical">
        <div class="num">{{index $c "critical"}}</div>
        <div class="label">Critical</div>
      </div>
      <div class="stat high">
        <div class="num">{{index $c "high"}}</div>
        <div class="label">High</div>
      </div>
      <div class="stat medium">
        <div class="num">{{index $c "medium"}}</div>
        <div class="label">Medium</div>
      </div>
      <div class="stat low">
        <div class="num">{{index $c "low"}}</div>
        <div class="label">Low / Advisory</div>
      </div>
    </div>

    {{if .SelfAudit}}
    <div class="self-audit {{if eq .SelfAudit "TAMPERED"}}tampered{{else if eq .SelfAudit "skipped"}}skipped{{else}}clean{{end}}">
      <span>self-audit:</span>
      <strong>{{.SelfAudit}}</strong>
    </div>
    {{end}}

    <div class="meta">
      <span>roots: <code>{{join .Roots " "}}</code></span>
      <span>files seen: {{.FilesSeen}}</span>
      <span>parsed: {{.FilesParsed}}</span>
      {{if gt .Suppressed 0}}<span>suppressed: {{.Suppressed}}</span>{{end}}
      {{if gt .Skipped 0}}<span>skipped: {{.Skipped}}</span>{{end}}
      <span>scan time: {{duration .StartedAt .FinishedAt}}</span>
    </div>
  </section>

  {{if eq (index $c "total") 0}}
    <div class="empty">
      <div class="check">✓</div>
      <div><strong>No findings</strong></div>
      <div>AgentGuard scanned {{.FilesParsed}} agent-config files and didn't find any policy violations.</div>
    </div>
  {{else}}
    <h2>Findings</h2>
    <ul class="findings">
      {{range .Findings}}
      <li class="finding">
        <div class="finding-head">
          <h3 class="finding-title">{{.Title}}</h3>
          <div class="badges">
            <span class="badge {{sevClass .Severity}}">{{sevLabel .Severity}}</span>
            <span class="badge tax {{taxClass .Taxonomy}}">{{.Taxonomy}}</span>
          </div>
        </div>
        <div class="path">{{.Path}}{{if gt .Line 0}}:{{.Line}}{{end}}</div>
        <div class="description">{{.Description}}</div>
        {{if .Match}}<div class="match">{{.Match}}</div>{{end}}
        {{if .SuggestedFix}}<div class="fix"><b>Fix:</b> {{.SuggestedFix}}</div>{{end}}
        <div class="rule-id">rule: {{.RuleID}}</div>
      </li>
      {{end}}
    </ul>
  {{end}}

  <footer>
    Generated by <a href="https://agentguard.dev">AgentGuard</a> {{.Version}} ·
    Found {{index $c "total"}} {{if eq (index $c "total") 1}}finding{{else}}findings{{end}} in {{.FilesParsed}} files
  </footer>
</div>
</body>
</html>

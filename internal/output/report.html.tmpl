<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>Audr Report</title>
<style>
  /* --- Embedded fonts (latin subset, base64 woff2) --------------------- */
  /* Embedded via go:embed at build time; rendered HTML makes zero external
     requests. Instrument Serif (display), Geist (body, variable 400-600),
     Geist Mono (mono). Total ~64KB woff2 / ~85KB after base64 inflate.   */
  @font-face {
    font-family: 'Instrument Serif';
    font-style: normal;
    font-weight: 400;
    font-display: swap;
    src: url({{fontURI "instrument_serif"}}) format('woff2');
  }
  @font-face {
    font-family: 'Geist';
    font-style: normal;
    font-weight: 400 600;
    font-display: swap;
    src: url({{fontURI "geist"}}) format('woff2');
  }
  @font-face {
    font-family: 'Geist Mono';
    font-style: normal;
    font-weight: 400 600;
    font-display: swap;
    src: url({{fontURI "geist_mono"}}) format('woff2');
  }

  /* --- Type system ------------------------------------------------------ */
  :root {
    --font-display: "Instrument Serif", ui-serif, "Iowan Old Style", Charter, Cambria, Georgia, serif;
    --font-body: "Geist", -apple-system, "SF Pro Text", "Segoe UI", "Helvetica Neue", Helvetica, Arial, sans-serif;
    --font-mono: "Geist Mono", ui-monospace, "SF Mono", Menlo, "Cascadia Mono", Consolas, monospace;
  }

  /* --- Forensic palette (light) ---------------------------------------- */
  :root {
    --paper:        #FAFAF8;   /* slightly warm off-white, document feel */
    --ink:          #14141A;   /* near-black, warmer than #000           */
    --ink-soft:     #4A4A52;   /* secondary text                         */
    --ink-muted:    #80808A;   /* tertiary, captions                     */
    --rule:         #1A1A22;   /* hairlines on light bg, document-strong */
    --rule-soft:    #E4E2DA;   /* dividers between cards                 */
    --card:         #FFFFFF;
    --card-tint:    #F4F1E8;   /* aged-paper tint for callouts           */

    --critical:     #6F0A12;   /* deep oxblood, not Tailwind red-700     */
    --critical-bg:  #FBF6F5;
    --high:         #8A3A0B;   /* burnt amber                            */
    --high-bg:      #FBF7F1;
    --medium:       #6B5A0E;   /* dark mustard                           */
    --medium-bg:    #FAF7EA;
    --low:          #3F3F46;
    --low-bg:       #F1EFE8;
    --clean:        #2F5D3A;   /* deep forest, not Tailwind green-600    */
    --clean-bg:     #F1F4EE;

    --tax-enforced:   #2F5D3A;
    --tax-detectable: #1F3D5C;
    --tax-advisory:   #5A574A;

    --accent:       #0B2545;   /* deep navy for interactive               */
  }

  /* --- Forensic palette (dark) ----------------------------------------- */
  @media (prefers-color-scheme: dark) {
    :root {
      --paper:        #0B0B0E;
      --ink:          #E8E4D6;
      --ink-soft:     #B8B4A6;
      --ink-muted:    #707070;
      --rule:         #C8C4B6;
      --rule-soft:    #232328;
      --card:         #14141A;
      --card-tint:    #1B1B22;

      --critical:     #E07A5F;
      --critical-bg:  #1F1414;
      --high:         #D29A4A;
      --high-bg:      #1F1A12;
      --medium:       #C8B85A;
      --medium-bg:    #1C1A12;
      --low:          #B0B0B0;
      --low-bg:       #18181C;
      --clean:        #7AB58A;
      --clean-bg:     #131A14;

      --tax-enforced:   #7AB58A;
      --tax-detectable: #7AA8D2;
      --tax-advisory:   #A8A496;

      --accent:       #BFD2EA;
    }
  }

  /* --- Reset / base ---------------------------------------------------- */
  * { box-sizing: border-box; }
  html, body { margin: 0; padding: 0; }
  body {
    font-family: var(--font-body);
    font-size: 15px;
    line-height: 1.6;
    color: var(--ink);
    background: var(--paper);
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    font-feature-settings: "ss01", "cv11";
  }
  ::selection { background: var(--ink); color: var(--paper); }

  .doc {
    max-width: 760px;
    margin: 0 auto;
    padding: 56px 28px 96px;
  }

  /* --- Document chrome ------------------------------------------------- */
  .eyebrow {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    border-bottom: 1px solid var(--rule);
    padding-bottom: 14px;
    font-family: var(--font-mono);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--ink-soft);
  }
  .eyebrow strong { color: var(--ink); font-weight: 600; }
  .eyebrow .tag-version { color: var(--ink-muted); }

  /* --- Verdict (the lead) --------------------------------------------- */
  .verdict {
    margin: 36px 0 32px;
  }
  .verdict-bar {
    width: 56px;
    height: 4px;
    background: var(--ink);
    margin-bottom: 28px;
  }
  .verdict-bar.critical { background: var(--critical); }
  .verdict-bar.high     { background: var(--high); }
  .verdict-bar.medium   { background: var(--medium); }
  .verdict-bar.low      { background: var(--low); }
  .verdict-bar.clean    { background: var(--clean); }

  .verdict-lead {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: 36px;
    line-height: 1.15;
    letter-spacing: -0.01em;
    color: var(--ink);
    margin: 0 0 14px;
  }
  .verdict-supporting {
    font-size: 14px;
    color: var(--ink-soft);
    margin: 0;
  }

  /* --- Metric strip (small, under verdict) ----------------------------- */
  .metrics {
    display: flex;
    flex-wrap: wrap;
    gap: 0;
    border-top: 1px solid var(--rule-soft);
    border-bottom: 1px solid var(--rule-soft);
    margin: 28px 0 36px;
    padding: 16px 0;
  }
  .metric {
    flex: 1 1 0;
    min-width: 96px;
    padding: 0 8px;
    border-right: 1px solid var(--rule-soft);
  }
  .metric:last-child { border-right: 0; }
  .metric-num {
    font-family: var(--font-display);
    font-size: 26px;
    line-height: 1;
    letter-spacing: -0.02em;
    color: var(--ink);
  }
  .metric.critical .metric-num { color: var(--critical); }
  .metric.high     .metric-num { color: var(--high); }
  .metric.medium   .metric-num { color: var(--medium); }
  .metric.low      .metric-num { color: var(--low); }
  .metric-label {
    font-family: var(--font-mono);
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--ink-muted);
    margin-top: 8px;
  }

  /* --- Audit / scan-meta line ----------------------------------------- */
  .meta-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 6px 28px;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--ink-soft);
    margin: 0 0 32px;
  }
  .meta-grid > div { display: flex; gap: 8px; }
  .meta-grid .k { color: var(--ink-muted); text-transform: uppercase; letter-spacing: 0.1em; min-width: 90px; }
  .meta-grid .v { color: var(--ink); word-break: break-all; }

  .self-audit {
    font-family: var(--font-mono);
    font-size: 12px;
    padding: 10px 14px;
    border: 1px solid currentColor;
    margin-bottom: 28px;
    display: flex;
    gap: 10px;
    align-items: center;
  }
  .self-audit.clean    { color: var(--clean); }
  .self-audit.tampered { color: var(--critical); border-width: 2px; }
  .self-audit.skipped  { color: var(--ink-muted); }
  .self-audit .k { text-transform: uppercase; letter-spacing: 0.14em; font-size: 10px; }

  .warnings {
    border: 2px solid var(--high);
    background: var(--high-bg);
    color: var(--ink);
    padding: 14px 16px;
    margin: 0 0 28px;
  }
  .warnings-title {
    font-family: var(--font-mono);
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--high);
    font-weight: 600;
    margin-bottom: 8px;
  }
  .warnings ul { margin: 0; padding-left: 20px; }
  .warnings li { margin: 4px 0; color: var(--ink-soft); }

  /* --- Section heading (small caps eyebrow) ---------------------------- */
  h2.section {
    font-family: var(--font-mono);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--ink-muted);
    font-weight: 600;
    margin: 48px 0 18px;
    padding-bottom: 8px;
    border-bottom: 1px solid var(--rule);
    display: flex;
    justify-content: space-between;
    align-items: baseline;
  }
  h2.section .count {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--ink-muted);
    letter-spacing: 0.14em;
  }

  /* --- Disclosure plumbing -------------------------------------------- */
  details > summary {
    cursor: pointer;
    list-style: none;
  }
  details > summary::-webkit-details-marker { display: none; }
  .disclose-toggle {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--ink-muted);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    user-select: none;
  }
  .disclose-toggle::before { content: "▸ "; display: inline-block; transition: transform 0.12s ease; }
  details[open] > summary .disclose-toggle::before { transform: rotate(90deg); }

  /* --- Attack chains (threat briefs) ---------------------------------- */
  .chain {
    background: var(--card);
    border: 1px solid var(--rule-soft);
    border-left: 4px solid var(--ink);
    padding: 24px 28px;
    margin-bottom: 18px;
    position: relative;
  }
  .chain.critical { border-left-color: var(--critical); }
  .chain.high     { border-left-color: var(--high); }
  .chain.medium   { border-left-color: var(--medium); }
  .chain.low      { border-left-color: var(--low); }

  .chain-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 16px;
    margin-bottom: 14px;
  }
  .chain-title {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: 22px;
    line-height: 1.25;
    color: var(--ink);
    margin: 0;
    letter-spacing: -0.005em;
  }
  .chain-outcome {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--ink);
    background: var(--card-tint);
    border-left: 3px solid currentColor;
    padding: 8px 12px;
    margin: 0 0 14px;
    line-height: 1.5;
    letter-spacing: 0.01em;
  }
  .chain-outcome .k {
    text-transform: uppercase;
    letter-spacing: 0.18em;
    font-size: 9.5px;
    color: var(--ink-muted);
    display: block;
    margin-bottom: 3px;
  }
  .chain.critical .chain-outcome { color: var(--critical); }
  .chain.high     .chain-outcome { color: var(--high); }
  .chain.medium   .chain-outcome { color: var(--medium); }
  .chain.low      .chain-outcome { color: var(--low); }
  .chain-outcome .text { color: var(--ink); }
  .chain-lede {
    color: var(--ink);
    font-size: 15px;
    line-height: 1.55;
    margin: 0 0 8px;
  }
  .chain-rest {
    color: var(--ink-soft);
    font-size: 14px;
    line-height: 1.65;
    margin: 12px 0 0;
    padding-top: 12px;
    border-top: 1px dashed var(--rule-soft);
  }
  .chain-lede strong, .chain-rest strong, .finding-desc strong { font-weight: 600; color: var(--ink); }
  .chain-lede code, .chain-rest code, .finding-desc code {
    font-family: var(--font-mono);
    font-size: 12px;
    background: var(--card-tint);
    padding: 1px 6px;
    border-radius: 2px;
  }
  .chain-disclose {
    margin: 8px 0 0;
  }
  .chain-disclose > summary {
    display: inline-flex;
    gap: 8px;
    align-items: center;
    padding: 4px 0;
  }
  .chain-foot {
    border-top: 1px solid var(--rule-soft);
    padding-top: 12px;
    margin-top: 14px;
    display: grid;
    grid-template-columns: 90px 1fr;
    gap: 6px 14px;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--ink-soft);
  }
  .chain-foot .k {
    color: var(--ink-muted);
    text-transform: uppercase;
    letter-spacing: 0.12em;
  }
  .chain-foot a {
    color: var(--accent);
    text-decoration: none;
    border-bottom: 1px solid currentColor;
  }
  .chain-foot a:hover { color: var(--ink); }

  /* --- Severity pill --------------------------------------------------- */
  .pill {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    padding: 4px 9px;
    border: 1px solid currentColor;
    flex-shrink: 0;
    white-space: nowrap;
  }
  .pill.critical { color: var(--critical); }
  .pill.high     { color: var(--high); }
  .pill.medium   { color: var(--medium); }
  .pill.low      { color: var(--low); }
  .pill.tax-enforced   { color: var(--tax-enforced); }
  .pill.tax-detectable { color: var(--tax-detectable); }
  .pill.tax-advisory   { color: var(--tax-advisory); }

  /* --- Findings grouped by file path ----------------------------------- */
  .path-group {
    margin-bottom: 32px;
  }
  .path-group-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 16px;
    border-top: 1px solid var(--rule);
    padding: 18px 0 6px;
    margin-bottom: 6px;
    cursor: pointer;
    list-style: none;
  }
  .path-group-head::-webkit-details-marker { display: none; }
  .path-group-head:hover .path-name { text-decoration: underline; text-decoration-color: var(--ink-muted); text-underline-offset: 4px; }
  .path-name {
    font-family: var(--font-mono);
    font-size: 14px;
    color: var(--ink);
    word-break: break-all;
  }
  .path-name .basename { color: var(--ink); font-weight: 600; }
  .path-name .dir { color: var(--ink-muted); }
  .path-counts {
    display: flex;
    gap: 6px;
    flex-shrink: 0;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }
  .path-count {
    padding: 2px 7px;
    border: 1px solid currentColor;
    color: var(--ink-muted);
  }
  .path-count.critical { color: var(--critical); }
  .path-count.high     { color: var(--high); }
  .path-count.medium   { color: var(--medium); }
  .path-count.low      { color: var(--low); }

  .findings { list-style: none; padding: 0; margin: 0; }
  .finding {
    border-left: 2px solid var(--rule-soft);
    margin: 4px 0;
    position: relative;
    background: transparent;
  }
  .finding.critical { border-left-color: var(--critical); }
  .finding.high     { border-left-color: var(--high); }
  .finding.medium   { border-left-color: var(--medium); }
  .finding.low      { border-left-color: var(--low); }

  .finding > summary {
    padding: 10px 14px 10px 18px;
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 6px 14px;
    align-items: baseline;
  }
  .finding > summary:hover { background: var(--card-tint); }
  details[open] > .finding-summary { background: var(--card-tint); }
  .finding-summary-row {
    display: flex;
    justify-content: space-between;
    gap: 14px;
    align-items: baseline;
    grid-column: 1 / -1;
  }
  .finding-title {
    font-family: var(--font-body);
    font-size: 14px;
    line-height: 1.4;
    font-weight: 500;
    color: var(--ink);
    margin: 0;
    letter-spacing: 0;
  }
  .finding-pills { display: flex; gap: 6px; flex-shrink: 0; }
  .finding-line {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--ink-muted);
    margin-left: 8px;
  }
  .finding-body {
    padding: 4px 14px 16px 18px;
    border-top: 1px dashed var(--rule-soft);
  }
  .finding-desc {
    font-size: 13.5px;
    color: var(--ink);
    line-height: 1.6;
    margin: 12px 0 10px;
  }
  .finding-match {
    background: var(--card-tint);
    font-family: var(--font-mono);
    font-size: 12px;
    padding: 10px 14px;
    margin: 8px 0;
    overflow-x: auto;
    white-space: pre-wrap;
    word-break: break-all;
    color: var(--ink);
    border-left: 2px solid var(--rule);
  }
  .finding-fix {
    font-size: 13px;
    color: var(--ink);
    margin: 10px 0 0;
    padding: 10px 14px;
    background: var(--card-tint);
    border-left: 2px solid var(--clean);
  }
  .finding-fix-label {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--clean);
    text-transform: uppercase;
    letter-spacing: 0.16em;
    font-weight: 600;
    display: block;
    margin-bottom: 4px;
  }
  .finding-rule {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--ink-muted);
    margin-top: 12px;
    letter-spacing: 0.04em;
  }
  .finding-rule .k {
    color: var(--ink-muted);
    text-transform: uppercase;
    letter-spacing: 0.16em;
    font-size: 10px;
    margin-right: 6px;
  }

  /* --- Empty state ----------------------------------------------------- */
  .empty {
    border: 1px solid var(--clean);
    background: var(--clean-bg);
    padding: 48px 32px;
    text-align: center;
    margin: 32px 0;
  }
  .empty-mark {
    font-family: var(--font-display);
    font-size: 56px;
    color: var(--clean);
    line-height: 1;
    margin-bottom: 14px;
  }
  .empty-title {
    font-family: var(--font-display);
    font-size: 24px;
    color: var(--ink);
    margin: 0 0 6px;
  }
  .empty-body {
    font-size: 14px;
    color: var(--ink-soft);
  }

  /* --- Footer ---------------------------------------------------------- */
  footer {
    margin-top: 64px;
    padding-top: 18px;
    border-top: 1px solid var(--rule);
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--ink-muted);
    letter-spacing: 0.04em;
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 8px;
  }
  footer a {
    color: var(--ink-soft);
    text-decoration: none;
    border-bottom: 1px solid var(--rule-soft);
  }
  footer a:hover { color: var(--ink); border-bottom-color: var(--ink); }

  /* --- Filter toolbar -------------------------------------------------- */
  /* Progressive: with no JS the chips render but do nothing and every
     section stays visible — matches pre-filter behavior. */
  .filters {
    margin: 0 0 28px;
    padding: 14px 16px;
    border: 1px solid var(--rule-soft);
    background: var(--card);
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .filters-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 8px 14px;
  }
  .filters-label {
    font-family: var(--font-mono);
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--ink-muted);
    min-width: 56px;
  }
  .chip {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink-soft);
    background: transparent;
    border: 1px solid var(--rule-soft);
    padding: 4px 10px;
    cursor: pointer;
    user-select: none;
    line-height: 1.4;
  }
  .chip input { position: absolute; opacity: 0; pointer-events: none; }
  .chip[data-on="1"] {
    color: var(--ink);
    border-color: var(--ink);
    background: var(--card-tint);
  }
  .chip .count {
    color: var(--ink-muted);
    font-size: 10px;
    letter-spacing: 0.04em;
  }
  .chip[data-on="1"] .count { color: var(--ink-soft); }
  .chip-sev.critical[data-on="1"] { color: var(--critical); border-color: var(--critical); }
  .chip-sev.high[data-on="1"]     { color: var(--high);     border-color: var(--high); }
  .chip-sev.medium[data-on="1"]   { color: var(--medium);   border-color: var(--medium); }
  .chip-sev.low[data-on="1"]      { color: var(--low);      border-color: var(--low); }
  .filters-search {
    flex: 1 1 220px;
    min-width: 0;
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--ink);
    background: transparent;
    border: 0;
    border-bottom: 1px solid var(--rule-soft);
    padding: 4px 2px;
    outline: none;
  }
  .filters-search:focus { border-bottom-color: var(--ink); }
  .filters-clear {
    font-family: var(--font-mono);
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--ink-muted);
    background: transparent;
    border: 0;
    cursor: pointer;
    padding: 4px 0;
  }
  .filters-clear:hover { color: var(--ink); }

  .is-filtered-out { display: none !important; }
  .filter-empty {
    display: none;
    border: 1px dashed var(--rule);
    padding: 24px 20px;
    text-align: center;
    color: var(--ink-soft);
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.06em;
    margin: 24px 0;
  }
  .filter-empty.is-shown { display: block; }

  /* --- Print ----------------------------------------------------------- */
  @media print {
    body { background: white; }
    .doc { max-width: 100%; padding: 0; }
    .chain, .finding-match, .finding-fix { break-inside: avoid; }
    a { color: inherit; }
    .filters, .filter-empty { display: none !important; }
    /* Print view restores everything — toolbar state is screen-only. */
    .is-filtered-out { display: revert !important; }
  }
</style>
</head>
<body>
<div class="doc">

  {{ $c := counts .Findings }}
  {{ $v := verdict . }}

  <div class="eyebrow">
    <span><strong>AUDR</strong> · scan report</span>
    <span class="tag-version">{{.Version}}</span>
  </div>

  <section class="verdict">
    <div class="verdict-bar {{$v.Severity}}"></div>
    <h1 class="verdict-lead">{{$v.Lead}}</h1>
    <p class="verdict-supporting">{{$v.Supporting}}</p>
  </section>

  <div class="metrics">
    <div class="metric critical"><div class="metric-num">{{index $c "critical"}}</div><div class="metric-label">Critical</div></div>
    <div class="metric high"><div class="metric-num">{{index $c "high"}}</div><div class="metric-label">High</div></div>
    <div class="metric medium"><div class="metric-num">{{index $c "medium"}}</div><div class="metric-label">Medium</div></div>
    <div class="metric low"><div class="metric-num">{{index $c "low"}}</div><div class="metric-label">Advisory</div></div>
    <div class="metric"><div class="metric-num">{{len .AttackChains}}</div><div class="metric-label">Chains</div></div>
  </div>

  <div class="meta-grid">
    <div><span class="k">Roots</span><span class="v">{{join .Roots " · "}}</span></div>
    <div><span class="k">Files</span><span class="v">{{.FilesParsed}} parsed / {{.FilesSeen}} seen{{if gt .Skipped 0}} · {{.Skipped}} skipped{{end}}{{if gt .Suppressed 0}} · {{.Suppressed}} suppressed{{end}}</span></div>
    <div><span class="k">Time</span><span class="v">{{duration .StartedAt .FinishedAt}}</span></div>
    <div><span class="k">Started</span><span class="v">{{.StartedAt.Format "2006-01-02 15:04:05 MST"}}</span></div>
  </div>

  {{if .SelfAudit}}
  <div class="self-audit {{if eq .SelfAudit "TAMPERED"}}tampered{{else if eq .SelfAudit "skipped"}}skipped{{else}}clean{{end}}">
    <span class="k">Self-audit</span>
    <strong>{{.SelfAudit}}</strong>
  </div>
  {{end}}

  {{if .Warnings}}
  <section class="warnings">
    <div class="warnings-title">Coverage warnings</div>
    <ul>
      {{range .Warnings}}<li>{{.}}</li>{{end}}
    </ul>
  </section>
  {{end}}

  {{- $secretFindingsAll := secretFindings .Findings }}
  {{- $packageFindingsAll := packageVulns .Findings }}
  {{- $otherFindings := otherFindings .Findings }}
  {{if or .AttackChains .Findings}}
  <nav class="filters" id="filters" aria-label="Result filters">
    <div class="filters-row">
      <span class="filters-label">Show</span>
      <label class="chip chip-kind" data-kind="chain" data-on="1">
        <input type="checkbox" checked aria-label="Toggle attack chains">
        Chains <span class="count">{{len .AttackChains}}</span>
      </label>
      <label class="chip chip-kind" data-kind="secret" data-on="1">
        <input type="checkbox" checked aria-label="Toggle secret findings">
        Secrets <span class="count">{{len $secretFindingsAll}}</span>
      </label>
      <label class="chip chip-kind" data-kind="package" data-on="1">
        <input type="checkbox" checked aria-label="Toggle package vulnerabilities">
        Packages <span class="count">{{len $packageFindingsAll}}</span>
      </label>
      <label class="chip chip-kind" data-kind="other" data-on="1">
        <input type="checkbox" checked aria-label="Toggle other findings">
        Other <span class="count">{{len $otherFindings}}</span>
      </label>
    </div>
    <div class="filters-row">
      <span class="filters-label">Severity</span>
      <label class="chip chip-sev critical" data-sev="critical" data-on="1">
        <input type="checkbox" checked aria-label="Toggle critical findings">
        Critical <span class="count">{{index $c "critical"}}</span>
      </label>
      <label class="chip chip-sev high" data-sev="high" data-on="1">
        <input type="checkbox" checked aria-label="Toggle high findings">
        High <span class="count">{{index $c "high"}}</span>
      </label>
      <label class="chip chip-sev medium" data-sev="medium" data-on="1">
        <input type="checkbox" checked aria-label="Toggle medium findings">
        Medium <span class="count">{{index $c "medium"}}</span>
      </label>
      <label class="chip chip-sev low" data-sev="low" data-on="1">
        <input type="checkbox" checked aria-label="Toggle low findings">
        Low <span class="count">{{index $c "low"}}</span>
      </label>
      <input type="search" class="filters-search" id="filter-search" placeholder="filter by text — rule, path, or title" aria-label="Filter findings by text">
      <button type="button" class="filters-clear" id="filter-clear">Reset</button>
    </div>
  </nav>
  <div class="filter-empty" id="filter-empty">No findings match the current filters.</div>
  {{end}}

  {{if .AttackChains}}
  <h2 class="section" data-kind="chain">
    <span>Attack Chains</span>
    <span class="count">{{len .AttackChains}} fired</span>
  </h2>

  {{range .AttackChains}}
  <article class="chain {{sevClass .Severity}}" data-kind="chain" data-sev="{{sevClass .Severity}}" data-search="{{searchText .Title .Outcome .Narrative}}">
    <div class="chain-head">
      <h3 class="chain-title">{{md .Title}}</h3>
      <span class="pill {{sevClass .Severity}}">{{sevLabel .Severity}}</span>
    </div>
    {{if .Outcome}}
    <div class="chain-outcome">
      <span class="k">Attacker gets</span>
      <span class="text">{{md .Outcome}}</span>
    </div>
    {{end}}
    <p class="chain-lede">{{narrativeLede .Narrative}}</p>
    {{ $rest := narrativeRest .Narrative }}
    {{if $rest}}
    <details class="chain-disclose">
      <summary><span class="disclose-toggle">Read full attacker walkthrough</span></summary>
      <div class="chain-rest">{{$rest}}</div>
    </details>
    {{end}}
    <div class="chain-foot">
      {{if .Paths}}
        <span class="k">Files</span>
        <span>
          {{range $i, $p := .Paths}}{{if $i}} · {{end}}<a href="#path-{{slug $p}}">{{basename $p}}</a>{{end}}
        </span>
      {{end}}
      {{if .FindingIDs}}
        <span class="k">Rules</span>
        <span>{{join .FindingIDs " · "}}</span>
      {{end}}
      {{if .Citations}}
        <span class="k">Citations</span>
        <span>{{join .Citations " · "}}</span>
      {{end}}
    </div>
  </article>
  {{end}}
  {{end}}

  {{if $secretFindingsAll}}
  <h2 class="section" data-kind="secret">
    <span>Secrets</span>
    <span class="count">{{len $secretFindingsAll}} secret exposure{{if ne (len $secretFindingsAll) 1}}s{{end}}</span>
  </h2>

  <ul class="findings secret-exposures">
    {{range $secretFindingsAll}}
    <li data-kind="secret" data-sev="{{sevClass .Severity}}" data-search="{{searchText .Title .RuleID .Path .Description}}">
      <details class="finding {{sevClass .Severity}}" open>
        <summary class="finding-summary">
          <div class="finding-summary-row">
            <span>
              <span class="finding-title">{{md .Title}}</span>
              {{if gt .Line 0}}<span class="finding-line">line {{.Line}}</span>{{end}}
            </span>
            <span class="finding-pills">
              <span class="pill {{sevClass .Severity}}">{{sevLabel .Severity}}</span>
            </span>
          </div>
        </summary>
        <div class="finding-body">
          <div class="finding-rule"><span class="k">File</span>{{.Path}}</div>
          <div class="finding-desc">{{md .Description}}</div>
          {{if .Match}}<pre class="finding-match">{{.Match}}</pre>{{end}}
          {{if .SuggestedFix}}
            <div class="finding-fix">
              <span class="finding-fix-label">Fix</span>
              {{md .SuggestedFix}}
            </div>
          {{end}}
          <div class="finding-rule"><span class="k">Rule</span>{{.RuleID}} · <span class="k">Class</span>{{.Taxonomy}}</div>
        </div>
      </details>
    </li>
    {{end}}
  </ul>
  {{end}}

  {{if $packageFindingsAll}}
  <h2 class="section" data-kind="package">
    <span>Package vulnerabilities</span>
    <span class="count">{{len $packageFindingsAll}} vulnerable package manifest{{if ne (len $packageFindingsAll) 1}}s{{end}}</span>
  </h2>

  <ul class="findings package-vulnerabilities">
    {{range $packageFindingsAll}}
    <li data-kind="package" data-sev="{{sevClass .Severity}}" data-search="{{searchText .Title .RuleID .Path .Description}}">
      <details class="finding {{sevClass .Severity}}" open>
        <summary class="finding-summary">
          <div class="finding-summary-row">
            <span>
              <span class="finding-title">{{md .Title}}</span>
              {{if gt .Line 0}}<span class="finding-line">line {{.Line}}</span>{{end}}
            </span>
            <span class="finding-pills">
              <span class="pill {{sevClass .Severity}}">{{sevLabel .Severity}}</span>
            </span>
          </div>
        </summary>
        <div class="finding-body">
          <div class="finding-rule"><span class="k">Manifest</span>{{.Path}}</div>
          <div class="finding-desc">{{md .Description}}</div>
          {{if .Match}}<pre class="finding-match">{{.Match}}</pre>{{end}}
          {{if .SuggestedFix}}
            <div class="finding-fix">
              <span class="finding-fix-label">Fix</span>
              {{md .SuggestedFix}}
            </div>
          {{end}}
          <div class="finding-rule"><span class="k">Rule</span>{{.RuleID}} · <span class="k">Class</span>{{.Taxonomy}}</div>
        </div>
      </details>
    </li>
    {{end}}
  </ul>
  {{end}}

  {{if eq (index $c "total") 0}}
    <section class="empty">
      {{if .Warnings}}
      <div class="empty-mark">!</div>
      <h2 class="empty-title">No findings in completed checks</h2>
      <p class="empty-body">Scanner coverage was incomplete. Resolve the coverage warnings above before treating this as a clean package-vulnerability report.</p>
      {{else}}
      <div class="empty-mark">✓</div>
      <h2 class="empty-title">No findings</h2>
      <p class="empty-body">Audr scanned {{.FilesParsed}} files and didn't find any developer-machine security findings.</p>
      {{end}}
    </section>
  {{else}}
    <h2 class="section" data-kind="files">
      <span>Findings by file</span>
      <span class="count">{{index $c "total"}} across {{len (groupByPath .Findings)}} files</span>
    </h2>

    {{range groupByPath .Findings}}
    <details class="path-group" open id="path-{{slug .Path}}" data-pathgroup="1">
      <summary class="path-group-head">
        <span class="path-name">{{.Path}}</span>
        <span class="path-counts">
          {{if gt .Crit 0}}<span class="path-count critical">{{.Crit}} crit</span>{{end}}
          {{if gt .High 0}}<span class="path-count high">{{.High}} high</span>{{end}}
          {{if gt .Med 0}}<span class="path-count medium">{{.Med}} med</span>{{end}}
          {{if gt .Low 0}}<span class="path-count low">{{.Low}} adv</span>{{end}}
        </span>
      </summary>

      <ul class="findings">
        {{range .Findings}}
        <li data-kind="{{findingKind .}}" data-sev="{{sevClass .Severity}}" data-search="{{searchText .Title .RuleID .Path .Description}}">
          <details class="finding {{sevClass .Severity}}">
            <summary class="finding-summary">
              <div class="finding-summary-row">
                <span>
                  <span class="finding-title">{{md .Title}}</span>
                  {{if gt .Line 0}}<span class="finding-line">line {{.Line}}</span>{{end}}
                </span>
                <span class="finding-pills">
                  <span class="pill {{sevClass .Severity}}">{{sevLabel .Severity}}</span>
                </span>
              </div>
            </summary>
            <div class="finding-body">
              <div class="finding-desc">{{md .Description}}</div>
              {{if .Match}}<pre class="finding-match">{{.Match}}</pre>{{end}}
              {{if .SuggestedFix}}
                <div class="finding-fix">
                  <span class="finding-fix-label">Fix</span>
                  {{md .SuggestedFix}}
                </div>
              {{end}}
              <div class="finding-rule"><span class="k">Rule</span>{{.RuleID}} · <span class="k">Class</span>{{.Taxonomy}}</div>
            </div>
          </details>
        </li>
        {{end}}
      </ul>
    </details>
    {{end}}
  {{end}}

  <footer>
    <span>Generated by <a href="https://audr.dev">Audr</a> {{.Version}}</span>
    <span>{{index $c "total"}} {{if eq (index $c "total") 1}}finding{{else}}findings{{end}} · {{len .AttackChains}} {{if eq (len .AttackChains) 1}}chain{{else}}chains{{end}} · {{.FilesParsed}} files</span>
  </footer>
</div>
<script>
(function () {
  var bar = document.getElementById('filters');
  if (!bar) return;
  var search = document.getElementById('filter-search');
  var clearBtn = document.getElementById('filter-clear');
  var emptyState = document.getElementById('filter-empty');

  var kindOn = { chain: true, secret: true, package: true, other: true };
  var sevOn  = { critical: true, high: true, medium: true, low: true };
  var query  = '';

  var items = document.querySelectorAll('[data-kind][data-sev]');
  var pathGroups = document.querySelectorAll('[data-pathgroup]');
  var sections = document.querySelectorAll('h2.section[data-kind]');

  function matches(el) {
    var kind = el.getAttribute('data-kind');
    var sev = el.getAttribute('data-sev');
    if (kindOn[kind] === false) return false;
    if (sevOn[sev] === false) return false;
    if (query) {
      var hay = (el.getAttribute('data-search') || '').toLowerCase();
      if (hay.indexOf(query) === -1) return false;
    }
    return true;
  }

  function apply() {
    var anyVisible = false;
    var kindHasVisible = { chain: false, secret: false, package: false, other: false };

    for (var i = 0; i < items.length; i++) {
      var el = items[i];
      if (matches(el)) {
        el.classList.remove('is-filtered-out');
        anyVisible = true;
        kindHasVisible[el.getAttribute('data-kind')] = true;
      } else {
        el.classList.add('is-filtered-out');
      }
    }

    for (var g = 0; g < pathGroups.length; g++) {
      var group = pathGroups[g];
      var visible = group.querySelectorAll('li[data-kind]:not(.is-filtered-out)');
      group.classList.toggle('is-filtered-out', visible.length === 0);
    }

    for (var s = 0; s < sections.length; s++) {
      var sec = sections[s];
      var sk = sec.getAttribute('data-kind');
      var hide = false;
      if (sk === 'chain' && !kindHasVisible.chain) hide = true;
      else if (sk === 'secret' && !kindHasVisible.secret) hide = true;
      else if (sk === 'package' && !kindHasVisible.package) hide = true;
      else if (sk === 'files') {
        hide = !(kindHasVisible.secret || kindHasVisible.package || kindHasVisible.other);
      }
      sec.classList.toggle('is-filtered-out', hide);
    }

    if (emptyState) emptyState.classList.toggle('is-shown', !anyVisible);
  }

  function bindChip(chip, store, key) {
    var input = chip.querySelector('input');
    chip.addEventListener('click', function (ev) {
      if (ev.target !== input) {
        ev.preventDefault();
        input.checked = !input.checked;
      }
      store[key] = !!input.checked;
      chip.setAttribute('data-on', input.checked ? '1' : '0');
      apply();
    });
  }

  var kindChips = bar.querySelectorAll('.chip-kind');
  for (var k = 0; k < kindChips.length; k++) {
    bindChip(kindChips[k], kindOn, kindChips[k].getAttribute('data-kind'));
  }
  var sevChips = bar.querySelectorAll('.chip-sev');
  for (var v = 0; v < sevChips.length; v++) {
    bindChip(sevChips[v], sevOn, sevChips[v].getAttribute('data-sev'));
  }

  if (search) {
    search.addEventListener('input', function () {
      query = search.value.trim().toLowerCase();
      apply();
    });
  }
  if (clearBtn) {
    clearBtn.addEventListener('click', function () {
      Object.keys(kindOn).forEach(function (k) { kindOn[k] = true; });
      Object.keys(sevOn).forEach(function (s) { sevOn[s] = true; });
      var chips = bar.querySelectorAll('.chip');
      for (var i = 0; i < chips.length; i++) {
        chips[i].setAttribute('data-on', '1');
        var input = chips[i].querySelector('input');
        if (input) input.checked = true;
      }
      if (search) { search.value = ''; query = ''; }
      apply();
    });
  }
})();
</script>
</body>
</html>
